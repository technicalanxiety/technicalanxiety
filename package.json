{
  "name": "astro-site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:cross-browser": "node scripts/cross-browser-test.js",
    "backlog": "node scripts/manage-backlog.js",
    "backlog:list": "node scripts/manage-backlog.js list",
    "backlog:check": "node scripts/manage-backlog.js check",
    "deploy:preview": "npm run build && npm run preview",
    "deploy:check": "npm run check && npm run test && npm run build",
    "verify:production": "node scripts/verify-deployment.js production",
    "verify:staging": "node scripts/verify-deployment.js staging"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.3",
    "fuse.js": "^7.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sass": "^1.97.0",
    "typescript": "^5.9.3"
  },
  "//overrides": "Remove yaml override when yaml-language-server ships with yaml >= 2.8.3 (GHSA-48c2-rrv3-qjmp)",
  "overrides": {
    "fast-xml-parser": "5.7.0",
    "yaml-language-server": {
      "yaml": "2.8.3"
    }
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.0.3",
    "fast-check": "^4.4.0",
    "jsdom": "^27.3.0",
    "lighthouse": "^13.1.0",
    "markdownlint-cli": "^0.48.0",
    "puppeteer": "^24.34.0",
    "sharp": "^0.34.5",
    "vitest": "^4.0.16"
  }
}
