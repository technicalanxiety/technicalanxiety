---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArchitectureMap from '../components/ArchitectureMap';
import { getPublishedPosts } from '../utils/posts';

const rawPosts = await getPublishedPosts();

const posts = rawPosts
  .filter(p => p.data.tags && p.data.tags.length > 0)
  .map(p => ({
    id:          p.id,
    title:       p.data.title,
    tags:        p.data.tags ?? [],
    date:        new Date(p.data.date).toISOString().slice(0, 10),
    description: p.data.description ?? '',
    url:         `/${p.id}/`,
    featured:    false,
  }));
---

<BaseLayout
  title="Architecture Map"
  description="A neural graph of every article on Technical Anxiety, connected by shared tags."
>
  <Header />

  <main style="position:relative;z-index:1;display:flex;flex-direction:column;height:calc(100vh - 60px);">

    <!-- Terminal chrome wrapper -->
    <div style="
      flex:1;
      display:flex;
      flex-direction:column;
      margin:20px 24px;
      background:#0d1117;
      border:1px solid var(--border-color);
      border-radius:12px;
      box-shadow:0 24px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(33,150,243,0.08);
      overflow:hidden;
      min-height:0;
    ">
      <!-- Title bar -->
      <div style="
        display:flex;
        align-items:center;
        gap:16px;
        padding:10px 16px;
        background:#161b22;
        border-bottom:1px solid var(--border-color);
        flex-shrink:0;
      ">
        <div style="display:flex;gap:7px;">
          <span style="width:12px;height:12px;border-radius:50%;background:#FF5F56;display:inline-block;"></span>
          <span style="width:12px;height:12px;border-radius:50%;background:#FFBD2E;display:inline-block;"></span>
          <span style="width:12px;height:12px;border-radius:50%;background:#27CA3F;display:inline-block;"></span>
        </div>
        <span style="font-family:'Fira Code',monospace;font-size:11px;color:#7d8590;">
          ~/technical-anxiety/architecture — graph.render()
        </span>
        <span style="
          margin-left:auto;
          font-family:'Fira Code',monospace;
          font-size:10px;
          color:#27CA3F;
          display:flex;
          align-items:center;
          gap:6px;
        ">
          <span class="live-dot"></span>
          LIVE
        </span>
      </div>

      <!-- React island fills the rest -->
      <div style="flex:1;min-height:0;">
        <ArchitectureMap client:load posts={posts} />
      </div>
    </div>

  </main>

  <Footer />
</BaseLayout>

<style>
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }
  .live-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #27CA3F;
    animation: pulse-dot 1.5s ease-in-out infinite;
  }
</style>
